##Código: Comparar caché caliente vs caché fría ejecutando el benchmark dos veces seguidas.

import time
import pandas as pd
import matplotlib.pyplot as plt


def cache_dual_size_test():
    tamanos = [50, 200] 
    block_size = 64 * 1024 
    resultados = []

    for mb in tamanos:
        file_path = DATA_DIR / f'cache_test_{mb}mb.bin'
        
       
        if not file_path.exists() or file_path.stat().st_size != (mb * 1024 * 1024):
            print(f"Generando archivo de {mb}MB...")
            data = os.urandom(block_size)
            with open(file_path, 'wb', buffering=0) as f:
                for _ in range(0, mb * 1024 * 1024, block_size):
                    f.write(data)

        
        for intento in ['Fría (Intento 1)', 'Caliente (Intento 2)']:
            
            time.sleep(1) 
            
            start_time = time.perf_counter()
            with open(file_path, 'rb', buffering=0) as f:
                while f.read(block_size):
                    pass
            elapsed = time.perf_counter() - start_time
            throughput = mb / elapsed
            
            resultados.append({
                'Tamaño_MB': mb,
                'Estado': intento,
                'Velocidad_MiB_s': throughput
            })
            print(f"Archivo {mb}MB - {intento}: {throughput:.2f} MiB/s")

    return pd.DataFrame(resultados)


df_cache_dual = cache_dual_size_test()


pivot_df = df_cache_dual.pivot(index='Tamaño_MB', columns='Estado', values='Velocidad_MiB_s')
ax = pivot_df.plot(kind='bar', figsize=(10, 6), color=['#1f77b4', '#ff7f0e'])
ax.set_title('Comparativa de Caché: 50MB vs 200MB')
ax.set_ylabel('Throughput (MiB/s)')
ax.set_xlabel('Tamaño del Archivo (MB)')
plt.xticks(rotation=0)
plt.grid(axis='y', linestyle='--', alpha=0.7)
plt.show()

print("\n--- Tabla de Resultados ---")
print(df_cache_dual)