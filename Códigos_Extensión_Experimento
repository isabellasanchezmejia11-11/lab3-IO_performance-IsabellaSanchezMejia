def benchmark_storage(path: Path, label: str, size_mb: int = 100):
    file_path = path / 'test_bench.bin'
    block_size = 64 * 1024 

    
    data = os.urandom(block_size)
    start_w = time.perf_counter()
    with open(file_path, 'wb', buffering=0) as f:
        for _ in range(0, size_mb * 1024 * 1024, block_size):
            f.write(data)
    w_time = time.perf_counter() - start_w
    
    
    start_r = time.perf_counter()
    with open(file_path, 'rb', buffering=0) as f:
        while f.read(block_size): pass
    r_time = time.perf_counter() - start_r
    
    return {
        'Almacenamiento': label,
        'Escritura_MiB_s': size_mb / w_time,
        'Lectura_MiB_s': size_mb / r_time
    }


